<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Círculo decorativo -->
    <View
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="-100dp"
        android:background="@drawable/circle_glow_top" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <!-- Icono -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text=""
                android:textSize="44sp"
                android:layout_marginBottom="8dp"/>

            <!-- Título pantalla -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Datos del Pedido"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.03"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Completa la información para continuar"
                android:textSize="13sp"
                android:textColor="#B0C4DE"
                android:layout_marginBottom="32dp"/>

            <!-- Sección Restaurante -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INFORMACIÓN DEL RESTAURANTE"
                android:textSize="11sp"
                android:textColor="#FF6B35"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:layout_marginBottom="20dp"
                android:elevation="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOMBRE DEL RESTAURANTE"
                    android:textSize="10sp"
                    android:textColor="#B0C4DE"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etNombreRestaurante"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="ej. PizzaRush"
                    android:textColorHint="#5A6A80"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/input_glass"
                    android:paddingHorizontal="16dp"
                    android:inputType="textCapWords"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RUBRO"
                    android:textSize="10sp"
                    android:textColor="#B0C4DE"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etRubro"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="ej. Pizzería al paso"
                    android:textColorHint="#5A6A80"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/input_glass"
                    android:paddingHorizontal="16dp"
                    android:inputType="textCapSentences"/>

            </LinearLayout>

            <!-- Sección Cliente -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INFORMACIÓN DEL CLIENTE"
                android:textSize="11sp"
                android:textColor="#FF6B35"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:layout_marginBottom="32dp"
                android:elevation="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOMBRE DEL CLIENTE"
                    android:textSize="10sp"
                    android:textColor="#B0C4DE"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etNombreCliente"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Tu nombre completo"
                    android:textColorHint="#5A6A80"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/input_glass"
                    android:paddingHorizontal="16dp"
                    android:inputType="textPersonName"/>

            </LinearLayout>

            <!-- Botón Continuar -->
            <Button
                android:id="@+id/btnContinuar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="CONTINUAR  →"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:elevation="8dp"/>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
